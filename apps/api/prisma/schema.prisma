generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ACCOUNTER
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String
  role             Role
  isActive         Boolean  @default(true)
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("users")
}

// All money amounts across the schema are stored as integer minor units
// (e.g. cents). `decimals` on Currency says how many decimals the minor
// unit has (USD: 2, SYP: 0).
model Currency {
  code        String   @id
  name        String
  symbol      String
  decimals    Int      @default(2)
  // How many units of this currency equal 1 unit of the base currency
  // (e.g. base USD, SYP ratePerBase = 13000). Base currency is always 1.
  ratePerBase Decimal  @default(1) @db.Decimal(18, 6)
  isBase      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  discounts DiscountDefinition[]
  courses   Course[]

  @@map("currencies")
}

enum CourseStatus {
  ACTIVE
  ARCHIVED
}

enum CompensationType {
  PERCENTAGE
  FIXED_COURSE
  FIXED_SESSION
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses CourseTeacher[]

  @@map("teachers")
}

model Course {
  id            String       @id @default(cuid())
  name          String
  description   String?
  priceMinor    Int
  currencyCode  String
  currency      Currency     @relation(fields: [currencyCode], references: [code])
  sessionsCount Int          @default(0)
  status        CourseStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  teachers CourseTeacher[]
  plans    PaymentPlanTemplate[]

  @@map("courses")
}

// Teacher compensation amounts are in the course's currency.
model CourseTeacher {
  id               String           @id @default(cuid())
  courseId         String
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId        String
  teacher          Teacher          @relation(fields: [teacherId], references: [id])
  compensationType CompensationType
  percent          Decimal?         @db.Decimal(5, 2)
  amountMinor      Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([courseId, teacherId])
  @@map("course_teachers")
}

model PaymentPlanTemplate {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  installments InstallmentTemplate[]

  @@unique([courseId, name])
  @@map("payment_plan_templates")
}

model InstallmentTemplate {
  id          String              @id @default(cuid())
  planId      String
  plan        PaymentPlanTemplate @relation(fields: [planId], references: [id], onDelete: Cascade)
  seq         Int
  amountMinor Int
  // Days after enrollment when this installment is due
  dueDays     Int

  @@unique([planId, seq])
  @@map("installment_templates")
}

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_methods")
}

model DiscountDefinition {
  id           String   @id @default(cuid())
  name         String   @unique
  amountMinor  Int
  currencyCode String
  currency     Currency @relation(fields: [currencyCode], references: [code])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("discount_definitions")
}
