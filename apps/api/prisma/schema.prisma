generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ACCOUNTER
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String
  role             Role
  isActive         Boolean  @default(true)
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  freeGrantedEnrollments Enrollment[]
  recordedPayments       PaymentTransaction[] @relation("RecordedBy")
  voidedPayments         PaymentTransaction[] @relation("VoidedBy")
  ledgerEntries          LedgerEntry[]
  teacherPayouts         TeacherPayout[]      @relation("PayoutCreatedBy")

  @@map("users")
}

// All money amounts across the schema are stored as integer minor units
// (e.g. cents). `decimals` on Currency says how many decimals the minor
// unit has (USD: 2, SYP: 0).
model Currency {
  code        String   @id
  name        String
  symbol      String
  decimals    Int      @default(2)
  // How many units of this currency equal 1 unit of the base currency
  // (e.g. base USD, SYP ratePerBase = 13000). Base currency is always 1.
  ratePerBase Decimal  @default(1) @db.Decimal(18, 6)
  isBase      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  discounts      DiscountDefinition[]
  courses        Course[]
  payments       PaymentTransaction[]
  ledgerEntries  LedgerEntry[]
  teacherPayouts TeacherPayout[]

  @@map("currencies")
}

enum CourseStatus {
  ACTIVE
  ARCHIVED
}

enum CompensationType {
  PERCENTAGE
  FIXED_COURSE
  FIXED_SESSION
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses CourseTeacher[]
  payouts TeacherPayout[]

  @@map("teachers")
}

model Course {
  id            String       @id @default(cuid())
  name          String
  description   String?
  priceMinor    Int
  currencyCode  String
  currency      Currency     @relation(fields: [currencyCode], references: [code])
  sessionsCount Int          @default(0)
  status        CourseStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  teachers       CourseTeacher[]
  plans          PaymentPlanTemplate[]
  enrollments    Enrollment[]
  teacherPayouts TeacherPayout[]

  @@map("courses")
}

// Teacher compensation amounts are in the course's currency.
model CourseTeacher {
  id               String           @id @default(cuid())
  courseId         String
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId        String
  teacher          Teacher          @relation(fields: [teacherId], references: [id])
  compensationType CompensationType
  percent          Decimal?         @db.Decimal(5, 2)
  amountMinor      Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([courseId, teacherId])
  @@map("course_teachers")
}

model PaymentPlanTemplate {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  installments InstallmentTemplate[]
  enrollments  Enrollment[]

  @@unique([courseId, name])
  @@map("payment_plan_templates")
}

model InstallmentTemplate {
  id          String              @id @default(cuid())
  planId      String
  plan        PaymentPlanTemplate @relation(fields: [planId], references: [id], onDelete: Cascade)
  seq         Int
  amountMinor Int
  // Days after enrollment when this installment is due
  dueDays     Int

  @@unique([planId, seq])
  @@map("installment_templates")
}

model Student {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]

  @@map("students")
}

// Installment amounts are in the course's currency. Discounts are baked into
// the installment amounts at enrollment (applied to the last installments
// first); the full-free badge is virtual — amounts stay intact and the API
// reports amount due as 0 while isFree is set, so it can be revoked cleanly.
model Enrollment {
  id             String               @id @default(cuid())
  studentId      String
  student        Student              @relation(fields: [studentId], references: [id])
  courseId       String
  course         Course               @relation(fields: [courseId], references: [id])
  planTemplateId String?
  planTemplate   PaymentPlanTemplate? @relation(fields: [planTemplateId], references: [id], onDelete: SetNull)
  enrolledAt     DateTime             @default(now())

  discountId          String?
  discount            DiscountDefinition? @relation(fields: [discountId], references: [id])
  discountAmountMinor Int?

  isFree          Boolean   @default(false)
  freeGrantedById String?
  freeGrantedBy   User?     @relation(fields: [freeGrantedById], references: [id])
  freeGrantedAt   DateTime?
  freeReason      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  installments Installment[]
  payments     PaymentTransaction[]

  @@unique([studentId, courseId])
  @@map("enrollments")
}

model Installment {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  seq          Int
  amountMinor  Int
  // Normalized to UTC midnight of the due day
  dueDate      DateTime
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  payments PaymentTransaction[]

  @@unique([enrollmentId, seq])
  @@map("installments")
}

// Payments are recorded in the course's currency (v1 constraint) with a
// snapshot of the currency's ratePerBase at entry time, so analytics in the
// base currency stay stable when rates change later. Voided payments keep
// their row for audit but are excluded from every sum.
model PaymentTransaction {
  id            String        @id @default(cuid())
  enrollmentId  String
  enrollment    Enrollment    @relation(fields: [enrollmentId], references: [id])
  installmentId String
  installment   Installment   @relation(fields: [installmentId], references: [id])
  amountMinor   Int
  currencyCode  String
  currency      Currency      @relation(fields: [currencyCode], references: [code])
  ratePerBase   Decimal       @db.Decimal(18, 6)
  methodId      String
  method        PaymentMethod @relation(fields: [methodId], references: [id])
  paidAt        DateTime      @default(now())
  note          String?
  recordedById  String
  recordedBy    User          @relation("RecordedBy", fields: [recordedById], references: [id])

  voidedAt   DateTime?
  voidedById String?
  voidedBy   User?     @relation("VoidedBy", fields: [voidedById], references: [id])
  voidReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enrollmentId])
  @@index([paidAt])
  @@map("payment_transactions")
}

enum LedgerEntryType {
  INCOME
  EXPENSE
}

model LedgerCategory {
  id        String          @id @default(cuid())
  name      String          @unique
  type      LedgerEntryType
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  entries LedgerEntry[]

  @@map("ledger_categories")
}

// General income/expense not related to courses (rent, salaries, ads,
// sponsorships...). Type is denormalized from the category; ratePerBase is a
// snapshot like on payments.
model LedgerEntry {
  id           String          @id @default(cuid())
  type         LedgerEntryType
  categoryId   String
  category     LedgerCategory  @relation(fields: [categoryId], references: [id])
  amountMinor  Int
  currencyCode String
  currency     Currency        @relation(fields: [currencyCode], references: [code])
  ratePerBase  Decimal         @db.Decimal(18, 6)
  date         DateTime        @default(now())
  note         String?
  createdById  String
  createdBy    User            @relation(fields: [createdById], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([date])
  @@map("ledger_entries")
}

// Money actually paid out to a teacher (counts as outcome — cash basis).
// When linked to a course the payout is in the course's currency.
model TeacherPayout {
  id           String   @id @default(cuid())
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  courseId     String?
  course       Course?  @relation(fields: [courseId], references: [id])
  amountMinor  Int
  currencyCode String
  currency     Currency @relation(fields: [currencyCode], references: [code])
  ratePerBase  Decimal  @db.Decimal(18, 6)
  date         DateTime @default(now())
  note         String?
  createdById  String
  createdBy    User     @relation("PayoutCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([teacherId])
  @@map("teacher_payouts")
}

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments PaymentTransaction[]

  @@map("payment_methods")
}

model DiscountDefinition {
  id           String   @id @default(cuid())
  name         String   @unique
  amountMinor  Int
  currencyCode String
  currency     Currency @relation(fields: [currencyCode], references: [code])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollments Enrollment[]

  @@map("discount_definitions")
}
