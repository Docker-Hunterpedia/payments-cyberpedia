NODE_ENV=development
PORT=3600

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://cyberpedia:cyberpedia@localhost:5432/cyberpedia_payments

# JWT — change these in production (min 16 chars)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Comma-separated list of allowed origins (empty = allow all)
CORS_ORIGIN=http://localhost:5173

# First admin user created by `pnpm db:seed`
SEED_ADMIN_EMAIL=admin@cyberpedia.local
SEED_ADMIN_PASSWORD=ChangeMe123!
